# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://invoice:invoice@db:5432/invoice_db
DATABASE_URL_SYNC=postgresql+psycopg2://invoice:invoice@db:5432/invoice_db

# ── Redis / task queue ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM (pick one; see app/core/llm.py for model selection logic) ─────
# Claude claude-opus-4-8 is the latest vision-capable model as of 2025-06
ANTHROPIC_API_KEY=sk-ant-...
# OR OpenAI GPT-4o
OPENAI_API_KEY=sk-...

# Which provider to use: "anthropic" | "openai"
LLM_PROVIDER=anthropic
# Model string — confirm latest at https://docs.anthropic.com/en/docs/about-claude/models
LLM_MODEL=claude-opus-4-8

# ── Slack ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APPROVAL_CHANNEL=#invoice-approvals

# ── LangSmith tracing ─────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=invoice-automation

# ── App settings ──────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
# Risk policy thresholds
RISK_AMOUNT_THRESHOLD=10000.00
